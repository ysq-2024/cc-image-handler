{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/image_handler.py --event pre_read",
            "timeout": 90,
            "statusMessage": "cc-image-handler: 正在用多模态模型分析图片"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/image_handler.py --event user_prompt",
            "timeout": 90,
            "statusMessage": "cc-image-handler: 检查 prompt 中的图片引用"
          }
        ]
      }
    ]
  }
}
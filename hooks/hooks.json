{
  "PreToolUse": [
    {
      "matcher": "Read",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/image_handler.py --event pre_read",
          "timeout": 90,
          "statusMessage": "Analyzing image with multimodal model"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/image_handler.py --event user_prompt",
          "timeout": 90,
          "statusMessage": "Checking prompt for image references"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/image_handler.py --event post_bash",
          "timeout": 90,
          "statusMessage": "Checking command output for produced images"
        }
      ]
    }
  ]
}